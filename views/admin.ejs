<%- include('partials/head', { title: 'Ticket-Übersicht', extraCss: ['/css/admin.css'] }) %>
<header class="admin-header">
  <div class="admin-header__inner">
    <div class="admin-brand">
      <img src="/images/logo.svg" alt="Küchen Obermeier" />
      <span>Service-Cockpit</span>
    </div>
    <form method="post" action="/logout">
      <button type="submit" class="button button--ghost">Abmelden</button>
    </form>
  </div>
</header>
<main class="admin-main">
  <section class="admin-section">
    <div class="admin-section__head">
      <div>
        <h1>Reklamationen</h1>
        <p>Alle Tickets nach Eingangsdatum sortiert. Farben zeigen den aktuellen Status.</p>
      </div>
      <div class="admin-legend">
        <span class="status status--new">Offen</span>
        <span class="status status--progress">In Bearbeitung / bestellt</span>
        <span class="status status--done">Erledigt</span>
      </div>
    </div>
    <div class="admin-table-wrapper">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Ticket</th>
            <th>Auftragsnummer</th>
            <th>Kunde</th>
            <th>Kontakt</th>
            <th>Eingang</th>
            <th>Status</th>
            <th>Aktion</th>
          </tr>
        </thead>
        <tbody>
          <% if (!tickets.length) { %>
            <tr>
              <td colspan="7" class="empty">Noch keine Reklamationen vorhanden.</td>
            </tr>
          <% } %>
          <% tickets.forEach((ticket) => { %>
            <tr class="status-row status-row--<%= ticket.status %>">
              <td data-label="Ticket">
                <a href="/admin/tickets/<%= ticket.id %>"><%= ticket.ticketNumber %></a>
              </td>
              <td data-label="Auftragsnummer"><%= ticket.orderNumber %></td>
              <td data-label="Kunde">
                <strong><%= ticket.customerName %></strong><br />
                <small><%= ticket.preferredContact === 'email' ? 'E-Mail bevorzugt' : 'Telefon bevorzugt' %></small>
              </td>
              <td data-label="Kontakt">
                <a href="tel:<%= ticket.phone %>"><%= ticket.phone %></a><br />
                <a href="mailto:<%= ticket.email %>"><%= ticket.email %></a>
              </td>
              <td data-label="Eingang"><%= dayjs(ticket.createdAt).format('DD.MM.YYYY HH:mm') %></td>
              <td data-label="Status">
                <span class="status status--<%= ticket.status %>">
                  <% if (ticket.status === 'new') { %>Offen<% } %>
                  <% if (ticket.status === 'progress') { %>In Bearbeitung<% } %>
                  <% if (ticket.status === 'ordered') { %>Bestellt<% } %>
                  <% if (ticket.status === 'done') { %>Erledigt<% } %>
                </span>
              </td>
              <td data-label="Aktion">
                <form method="post" action="/admin/tickets/<%= ticket.id %>/status" class="status-form">
                  <select name="status">
                    <option value="new" <%= ticket.status === 'new' ? 'selected' : '' %>>Offen</option>
                    <option value="progress" <%= ticket.status === 'progress' ? 'selected' : '' %>>In Bearbeitung</option>
                    <option value="ordered" <%= ticket.status === 'ordered' ? 'selected' : '' %>>Bestellt</option>
                    <option value="done" <%= ticket.status === 'done' ? 'selected' : '' %>>Erledigt</option>
                  </select>
                  <button type="submit" class="button button--small">Speichern</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>
</main>
<script src="https://cdn.jsdelivr.net/npm/dayjs@1/dayjs.min.js" defer></script>
<script src="/js/admin.js" defer></script>
</body>
</html>
